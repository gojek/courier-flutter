ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CourierCore" "${PODS_CONFIGURATION_BUILD_DIR}/ReachabilitySwift" "${PODS_CONFIGURATION_BUILD_DIR}/courier_dart_sdk" "${PODS_CONFIGURATION_BUILD_DIR}/permission_handler_apple" "${PODS_ROOT}/MQTTClientGJ" "${PODS_XCFRAMEWORKS_BUILD_DIR}/MQTTClientGJ"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CourierCore/CourierCore.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/ReachabilitySwift/Reachability.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/courier_dart_sdk/courier_dart_sdk.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/permission_handler_apple/permission_handler_apple.framework/Headers"
LIBRARY_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CourierMQTT" "${PODS_CONFIGURATION_BUILD_DIR}/CourierMQTTChuck" "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift
OTHER_CFLAGS = $(inherited) -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/CourierMQTT/CourierMQTT.modulemap" -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/CourierMQTTChuck/CourierMQTTChuck.modulemap"
OTHER_LDFLAGS = $(inherited) -ObjC -l"CourierMQTT" -l"CourierMQTTChuck" -framework "CoreTelephony" -framework "CourierCore" -framework "MQTTClientGJ" -framework "Reachability" -framework "SystemConfiguration" -framework "courier_dart_sdk" -framework "permission_handler_apple"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/CourierCore" "-F${PODS_CONFIGURATION_BUILD_DIR}/CourierMQTT" "-F${PODS_CONFIGURATION_BUILD_DIR}/CourierMQTTChuck" "-F${PODS_CONFIGURATION_BUILD_DIR}/Flutter" "-F${PODS_CONFIGURATION_BUILD_DIR}/MQTTClientGJ" "-F${PODS_CONFIGURATION_BUILD_DIR}/ReachabilitySwift" "-F${PODS_CONFIGURATION_BUILD_DIR}/courier_dart_sdk" "-F${PODS_CONFIGURATION_BUILD_DIR}/permission_handler_apple"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/CourierMQTT/CourierMQTT.modulemap" -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/CourierMQTTChuck/CourierMQTTChuck.modulemap"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
SWIFT_INCLUDE_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CourierMQTT" "${PODS_CONFIGURATION_BUILD_DIR}/CourierMQTTChuck"
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
